  "keyFeatures": [
    "OpenID4VP 1.0 protocol implementation",
    "Same-device and cross-device presentation flows",
    "MSO MDoc and SD-JWT VC credential format support",
    "DCQL query support for credential requests",
    "Trust source configuration (LOTL, Trust Lists, Keystores)",
    "JAR (JWT-secured Authorization Request) signing",
    "Response encryption with multiple algorithms",
    "QR code generation for cross-device flows",
    "Transaction-based presentation lifecycle"
  ],
  "publicApiSurface": [
    "POST /ui/presentations - Initialize transaction",
    "GET /ui/presentations/{transactionId} - Get wallet response",
    "GET /ui/presentations/{transactionId}/events - Get presentation events",
    "GET /wallet/request.jwt/{requestId} - Get request object (GET)",
    "POST /wallet/request.jwt/{requestId} - Get request object (POST)",
    "POST /wallet/direct_post/{requestId} - Direct post wallet response",
    "GET /wallet/public-keys.json - Get public JWK set",
    "POST /utilities/validations/msoMdoc/deviceResponse - Validate MSO MDoc"
  ]
}
